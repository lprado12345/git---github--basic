   "source": [
    " ## Part 1\n",
    "\n",
    "import random\n",
    "\n",
    "filename = \"random_numbers.txt\"\n",
    "\n",
    "# open file for writing\n",
    "f = open(filename, \"w\")\n",
    "\n",
    "# generate 500 random integers\n",
    "for n in range(1, 501):\n",
    "    value = random.randint(1, n)\n",
    "    f.write(str(value) + \"\\n\")\n",
    "\n",
    "# close the file\n",
    "f.close()\n"
   ]
